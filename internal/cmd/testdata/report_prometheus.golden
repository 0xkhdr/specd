# HELP specd_task_total Number of tasks in the spec.
# TYPE specd_task_total gauge
specd_task_total{spec="metrics-spec"} 2
# HELP specd_telemetry_duration_ms Host-reported task duration roll-up in milliseconds.
# TYPE specd_telemetry_duration_ms gauge
specd_telemetry_duration_ms{spec="metrics-spec"} 4000
# HELP specd_telemetry_verify_duration_ms Verification duration roll-up in milliseconds.
# TYPE specd_telemetry_verify_duration_ms gauge
specd_telemetry_verify_duration_ms{spec="metrics-spec"} 600
# HELP specd_telemetry_tokens Host-reported token roll-up.
# TYPE specd_telemetry_tokens gauge
specd_telemetry_tokens{spec="metrics-spec"} 120
# HELP specd_telemetry_cost_usd Host-reported cost roll-up in USD.
# TYPE specd_telemetry_cost_usd gauge
specd_telemetry_cost_usd{spec="metrics-spec",annotated="true"} 1.000000
# HELP specd_telemetry_retries Retry roll-up.
# TYPE specd_telemetry_retries gauge
specd_telemetry_retries{spec="metrics-spec"} 1
specd_wave_task_total{spec="metrics-spec",wave="1"} 1
specd_wave_telemetry_duration_ms{spec="metrics-spec",wave="1"} 1000
specd_wave_telemetry_verify_duration_ms{spec="metrics-spec",wave="1"} 200
specd_wave_telemetry_tokens{spec="metrics-spec",wave="1"} 50
specd_wave_telemetry_cost_usd{spec="metrics-spec",wave="1",annotated="true"} 0.250000
specd_wave_telemetry_retries{spec="metrics-spec",wave="1"} 1
specd_wave_task_total{spec="metrics-spec",wave="2"} 1
specd_wave_telemetry_duration_ms{spec="metrics-spec",wave="2"} 3000
specd_wave_telemetry_verify_duration_ms{spec="metrics-spec",wave="2"} 400
specd_wave_telemetry_tokens{spec="metrics-spec",wave="2"} 70
specd_wave_telemetry_cost_usd{spec="metrics-spec",wave="2",annotated="true"} 0.750000
specd_wave_telemetry_retries{spec="metrics-spec",wave="2"} 0
