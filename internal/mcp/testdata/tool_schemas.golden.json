  "specd_init": {
    "type": "object",
    "properties": {
      "agent": {
        "type": "string",
        "description": "Coding-agent selection: auto, all, none, codex, claude-code, cursor, gemini, or vscode"
      },
      "args": {
        "type": "array",
        "description": "Positional arguments, in order. Usage: specd init [--agent \u003cname\u003e] [--yes] [--dry-run]",
        "items": {
          "type": "string"
        }
      },
      "dry-run": {
        "type": "boolean",
        "description": "Preview exact actions without writing"
      },
      "force": {
        "type": "boolean",
        "description": "Destructively overwrite all scaffold files and AGENTS.md"
      },
      "json": {
        "type": "boolean",
        "description": "Output one versioned InitResult document"
      },
      "list-packs": {
        "type": "boolean",
        "description": "List the embedded spec packs and exit"
      },
      "non-interactive": {
        "type": "boolean",
        "description": "Disable prompts"
      },
      "pack": {
        "type": "string",
        "description": "Apply a spec pack by built-in name or http(s) URL"
      },
      "refresh": {
        "type": "boolean",
        "description": "Refresh frozen managed assets and AGENTS.md markers"
      },
      "repair": {
        "type": "boolean",
        "description": "Restore missing managed assets only"
      },
      "scope": {
        "type": "string",
        "description": "Integration scope (default project)"
      },
      "sha256": {
        "type": "string",
        "description": "Pinned SHA256 digest required for a remote --pack URL"
      },
      "verbose": {
        "type": "boolean",
        "description": "Include detailed path results"
      },
      "yes": {
        "type": "boolean",
        "description": "Accept non-destructive project-scoped integration changes"
      }
    }
  },
