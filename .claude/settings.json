{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "deny": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git commit --amend)",
      "Bash(git commit --amend *)",
      "Bash(git rebase)",
      "Bash(git rebase *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git filter-branch *)",
      "Bash(git update-ref *)",
      "Bash(git remote add *)",
      "Bash(git remote set-url *)",
      "Bash(gh pr merge *)",
      "Bash(gh release create *)"
    ]
  }
}
